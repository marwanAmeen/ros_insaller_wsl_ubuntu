#!/usr/bin/env bash
set -euo pipefail

# ROS 2 Humble installer for WSL Ubuntu 22.04
# Run as normal user (not root): ./install_ros2_humble_wsl.sh

fail() {
  echo "[ERROR] $1" >&2
  exit 1
}

info() {
  echo "[INFO] $1"
}

# ---------- Preflight checks ----------
if [ "$(id -u)" -eq 0 ]; then
  fail "Do not run as root. Run as your normal WSL user with sudo access."
fi

if ! grep -qiE "(microsoft|wsl)" /proc/version 2>/dev/null; then
  fail "This does not look like WSL. Please run inside WSL Ubuntu."
fi

if [ ! -f /etc/os-release ]; then
  fail "/etc/os-release not found. Unsupported Linux distro."
fi

# shellcheck disable=SC1091
. /etc/os-release

if [ "${ID:-}" != "ubuntu" ]; then
  fail "This script supports Ubuntu only. Detected: ${ID:-unknown}"
fi

if [ "${VERSION_ID:-}" != "22.04" ]; then
  fail "ROS 2 Humble is targeted for Ubuntu 22.04. Detected: ${VERSION_ID:-unknown}"
fi

ARCH="$(dpkg --print-architecture)"
if [ "$ARCH" != "amd64" ] && [ "$ARCH" != "arm64" ]; then
  fail "Unsupported architecture: $ARCH (expected amd64 or arm64)"
fi

if ! command -v sudo >/dev/null 2>&1; then
  fail "sudo is not installed. Install sudo first."
fi

if ! sudo -v; then
  fail "sudo authentication failed."
fi

if ! command -v curl >/dev/null 2>&1; then
  info "curl not found; it will be installed."
fi

# ---------- Base packages ----------
info "Updating apt metadata..."
sudo apt update

info "Installing prerequisite packages..."
sudo apt install -y \
  locales \
  curl \
  gnupg2 \
  lsb-release \
  software-properties-common \
  ca-certificates

# ---------- Locale ----------
info "Configuring locale en_US.UTF-8..."
sudo locale-gen en_US en_US.UTF-8
sudo update-locale LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# ---------- Repositories ----------
info "Ensuring 'universe' repository is enabled..."
sudo add-apt-repository -y universe

info "Adding ROS 2 apt key..."
sudo mkdir -p /usr/share/keyrings
sudo curl -fsSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
  -o /usr/share/keyrings/ros-archive-keyring.gpg

info "Adding ROS 2 apt repository..."
echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu ${UBUNTU_CODENAME} main" \
  | sudo tee /etc/apt/sources.list.d/ros2.list >/dev/null

# ---------- ROS install ----------
info "Updating apt metadata after adding ROS repo..."
sudo apt update

info "Installing ROS 2 Humble Desktop + tools..."
sudo apt install -y \
  ros-humble-desktop \
  python3-rosdep \
  python3-colcon-common-extensions \
  python3-argcomplete

# ---------- rosdep ----------
info "Initializing rosdep (safe if already initialized)..."
if [ ! -f /etc/ros/rosdep/sources.list.d/20-default.list ]; then
  sudo rosdep init
else
  info "rosdep already initialized, skipping rosdep init."
fi

info "Updating rosdep..."
rosdep update

# ---------- Shell environment ----------
BASHRC="$HOME/.bashrc"
ROS_SOURCE_LINE="source /opt/ros/humble/setup.bash"

info "Configuring persistent ROS environment in ${BASHRC}..."
if [ ! -f "$BASHRC" ]; then
  touch "$BASHRC"
fi

if ! grep -Fq "$ROS_SOURCE_LINE" "$BASHRC"; then
  printf "\n# ROS 2 Humble\n%s\n" "$ROS_SOURCE_LINE" >> "$BASHRC"
  info "Added ROS setup line to ${BASHRC}."
else
  info "ROS setup line already exists in ${BASHRC}."
fi

# Load for current shell
# shellcheck disable=SC1090
source /opt/ros/humble/setup.bash

info "Verifying ROS CLI..."
if command -v ros2 >/dev/null 2>&1; then
  info "ROS 2 installation completed successfully."
  ros2 --version || true
else
  fail "ros2 command not found after installation."
fi

echo
echo "Done. Open a new WSL terminal or run:"
echo "  source ~/.bashrc"
echo "Then test with:"
echo "  ros2 run demo_nodes_cpp talker"
echo "In another terminal:"
echo "  ros2 run demo_nodes_py listener"
